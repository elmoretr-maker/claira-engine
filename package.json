{
  "name": "claira-engine",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "bin": {
    "claira": "cli/claira.mjs"
  },
  "scripts": {
    "start": "node index.js",
    "claira": "node cli/claira.mjs",
    "build:references": "node vision/buildReferences.js",
    "generate:reference-assets": "node dev/generate_pack_reference_assets.mjs",
    "generate:pack-system": "node dev/generate_pack_system.mjs",
    "ui:dev": "vite --config ui/vite.config.mjs",
    "ui:build": "vite build --config ui/vite.config.mjs",
    "start:server": "node --env-file=.env server/index.js",
    "watch": "node server/watcher.js"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.65",
    "@xenova/transformers": "^2.17.2",
    "chalk": "^5.6.2",
    "chokidar": "^4.0.3",
    "express": "^4.21.2",
    "pdfjs-dist": "^4.10.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "tesseract.js": "^6.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^5.4.11"
  },
  "overrides": {
    "@xenova/transformers": {
      "sharp": "$sharp"
    }
  }
}
