# =============================================================================
# Claira Engine — environment template (copy to `.env` at repo root; never commit secrets)
# Load: Node 20+ → `node --env-file=.env server/index.js` (see package.json `start:server`).
# Vite reads the same repo-root `.env` for dev (e.g. PORT for API proxy target).
# =============================================================================

# -----------------------------------------------------------------------------
# Standard (optional — often set by your shell or process manager instead of .env)
# -----------------------------------------------------------------------------
NODE_ENV=development

# -----------------------------------------------------------------------------
# API server
# -----------------------------------------------------------------------------
# Optional — Express listen port. Default in code: 3000.
# Vite dev proxies all /__claira/* and /api/* routes to this port.
PORT=3000

# -----------------------------------------------------------------------------
# Engine mode
# -----------------------------------------------------------------------------
# Optional — Controls simulation vs real integrations. Default: simulation.
#   simulation — uses mock adapters (safe for dev / onboarding)
#   real       — expects live external APIs (Shopify, Wix, etc.)
# No rebuild required; set here and restart the server.
# CLAIRA_SYSTEM_MODE=simulation

# -----------------------------------------------------------------------------
# Hugging Face — CLIP zero-shot (workflow/integrations/providers/hfInferenceWorker.mjs)
# Only needed when running the HF inference path (token + worker). Omit if you never use CLIP.
# Token: https://huggingface.co/settings/tokens
# -----------------------------------------------------------------------------
# Optional — Inference API token (aliases HF_TOKEN / HUGGING_FACE_HUB_TOKEN also supported in worker).
HUGGINGFACE_API_TOKEN=your_token_here

# Optional — transformers.js ONNX model id (default: Xenova/clip-vit-base-patch32, same arch as openai/clip-vit-base-patch32).
# HF_CLIP_ENDPOINT is no longer used (legacy Inference API routes were removed).
HF_CLIP_MODEL=Xenova/clip-vit-base-patch32

# Optional — Request timeout in ms (default in code: 45000).
HF_TIMEOUT_MS=45000

# Optional — Set to 1 to skip live HF calls (tests / CI). Values other than 1 do not disable.
HF_DISABLE=0

# -----------------------------------------------------------------------------
# TTS — Edge (default) and/or ElevenLabs (lib/clairaTts.mjs, lib/clairaEdgeTtsVoice.mjs, lib/clairaElevenLabsVoice.mjs)
# -----------------------------------------------------------------------------
# Optional — ElevenLabs API key. Required only if CLAIRA_TTS_PROVIDER is `elevenlabs`, or `auto` when you want ElevenLabs tried first.
# https://elevenlabs.io/ → Profile → API key
ELEVENLABS_API_KEY=

# Optional — ElevenLabs model id (default in code: eleven_turbo_v2_5). Examples: eleven_turbo_v2_5, eleven_flash_v2_5
ELEVENLABS_MODEL_ID=

# Optional — TTS backend: edge (default) | elevenlabs | auto
#   edge — Microsoft Edge neural only (no ElevenLabs).
#   elevenlabs — ElevenLabs only (needs ELEVENLABS_API_KEY).
#   auto — try ElevenLabs if key is set, fall back to Edge on quota/errors.
# CLAIRA_TTS_PROVIDER=edge

# Optional — Microsoft Edge neural voice id. Examples: en-US-JennyNeural, en-US-AriaNeural
# CLAIRA_EDGE_TTS_VOICE=en-US-JennyNeural

# Optional — Edge TTS request timeout in ms (omit to use code default).
CLAIRA_EDGE_TTS_TIMEOUT_MS=15000

# Optional — ElevenLabs voice id (overrides default in lib/clairaElevenLabsVoice.mjs). ELEVENLABS_JADE_VOICE_ID is not used.
ELEVENLABS_VOICE_ID=

# -----------------------------------------------------------------------------
# Pre-baked voice assets (ui/public/assets/audio/voice/) — see npm run generate:voice-assets
# -----------------------------------------------------------------------------
# After running generate:voice-assets, onboarding lines play from disk (in-browser HTMLAudioElement) before any stream TTS.
# Optional — set to 0 to disable stream fallback when text is not in voice-manifest (default: unset = enabled).
# VITE_VOICE_STREAM_FALLBACK=1

# -----------------------------------------------------------------------------
# Asset Orchestration Engine — New_Arrival (workflow/watcher/folderWatcher.js)
# -----------------------------------------------------------------------------
# Optional — Verbose orchestration trace (slot order, Claira prep stub). Set to 1 / true / yes.
# ASSET_ORCHESTRATION_LOG=1

# Optional — Folder watcher (defaults: New_Arrival, Assets, autoProcess on).
# WATCH_FOLDER=New_Arrival
# DESTINATION_ROOT=Assets
# AUTO_PROCESS=true
# DRY_RUN=false
# WATCH_DEBOUNCE_MS=450

# -----------------------------------------------------------------------------
# Legacy Claira watcher (server/watcher.js — runProcessItemsPipeline)
# Inactive by default. New_Arrival ingestion uses: npm run watch:workflow
# -----------------------------------------------------------------------------
# Set to 1 only if you need the legacy processFolder-style watcher on New_Arrival.
# CLAIRA_LEGACY_WATCHER=1

# -----------------------------------------------------------------------------
# Access control (applies to /api/claira/* and /api/integrations/*)
# -----------------------------------------------------------------------------
# CLAIRA_REQUIRE_API_KEY — set to "true" to enforce key on external API routes.
#   false (default) → missing key is allowed; a warning is logged (soft mode).
#   true            → missing or invalid key returns 401.
# Does NOT apply to /__claira/run (internal/UI use remains unrestricted).
CLAIRA_REQUIRE_API_KEY=false

# CLAIRA_RATE_LIMIT — max requests per API key per 60-second window.
# Default: 60. Only applies when a valid key is present.
CLAIRA_RATE_LIMIT=60

# CLAIRA_API_KEY — API key recognised by the in-memory registry (dev seed).
# Add real keys programmatically via the apiKeys Map in server/index.js.
# CLAIRA_API_KEY=your-secret-key

# -----------------------------------------------------------------------------
# Debug / logging (server-side — server/clairaImagePipeline.js)
# -----------------------------------------------------------------------------
# Optional — Extra JSON logging for the image pipeline. Runtime enables when the variable is set to any non-empty string (including "0").
# To disable: omit CLAIRA_DEBUG or set it to an empty value in your environment — do not rely on =0 alone.
CLAIRA_DEBUG=0
