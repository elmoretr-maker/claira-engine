# ElevenLabs — https://elevenlabs.io/ → Profile → API key
ELEVENLABS_API_KEY=

# TTS model (free tier no longer allows v1 monolingual). Default in code: eleven_turbo_v2_5
# ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
# ELEVENLABS_MODEL_ID=eleven_flash_v2_5

# TTS backend: edge (default) | elevenlabs | auto
# - edge: Microsoft Edge neural only (single voice path; no ElevenLabs).
# - elevenlabs: ElevenLabs only (optional; requires key + plan).
# - auto: try ElevenLabs when key set, then fall back to Edge on errors.
# CLAIRA_TTS_PROVIDER=edge

# Optional: Edge voice id (Microsoft neural). Examples: en-US-JennyNeural, en-US-AriaNeural
# CLAIRA_EDGE_TTS_VOICE=en-US-JennyNeural

# Voice ID for TTS (API). Resolution order is in lib/clairaElevenLabsVoice.mjs.
#
# Free tier / testing (premade feminine “Sarah” — not Voice Library):
# ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
#
# Paid / Voice Library (e.g. Jade) — free API often returns 402 for library voices:
# ELEVENLABS_JADE_VOICE_ID=your_voice_id_here

# API server port (Express). Vite dev proxies /__claira/tts here.
# PORT=3000
