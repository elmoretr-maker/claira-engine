# ElevenLabs — https://elevenlabs.io/ → Profile → API key
ELEVENLABS_API_KEY=your_api_key_here

# Voice ID for TTS (API). Resolution order is in lib/clairaElevenLabsVoice.mjs.
#
# Free tier / testing (premade feminine “Sarah” — not Voice Library):
# ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
#
# Paid / Voice Library (e.g. Jade) — free API often returns 402 for library voices:
# ELEVENLABS_JADE_VOICE_ID=your_voice_id_here

# API server port (Express). Vite dev proxies /__claira/tts here.
# PORT=3000
